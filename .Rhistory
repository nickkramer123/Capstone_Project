GSS_metadata1 <- read.dct("GSS_.dct")
GSS_ascii1 <- read.dat("GSS_.dat", GSS_metadata1)
attr(GSS_ascii1, "col.label") <- GSS_metadata1[["ColLabel"]]
GSS1 <- GSS_ascii1
GSS_metadata <- read.dct("data/GSS.dct")
GSS_ascii <- read.dat("data/GSS.dat", GSS_metadata)
attr(GSS_ascii, "col.label") <- GSS_metadata[["ColLabel"]]
GSS <- GSS_ascii
GSS <- GSS + GSS1$REG16_7222 + GSS1$CLASS_
View(GSS)
GSS$REG16 <- GSS1$REG16_7222
GSS$CLASS <- GSS1$CLASS_
View(GSS)
